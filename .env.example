WEATHER_API_KEY=your_weather_api_key

# Required for writing all saved data to Firestore through Firebase Admin SDK.
# Recommended local setup:
# 1. Firebase Console -> Project settings -> Service accounts -> Generate new private key.
# 2. Convert the downloaded JSON to base64.
# 3. Paste it here as one line.
FIREBASE_SERVICE_ACCOUNT_BASE64=base64_encoded_service_account_json

# Alternative: use a one-line JSON string instead of base64.
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

# Production should verify Firebase ID tokens with Admin SDK.
# Keep this false/omitted in local dev only if you intentionally want auth fallback.
DISABLE_DEV_AUTH_FALLBACK=true
