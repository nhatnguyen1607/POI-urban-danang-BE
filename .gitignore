# 1. Chặn các thư mục thư viện và file build
/node_modules/
.env

# 2. Chặn toàn bộ thư mục model_saved của các version cũ để tiết kiệm dung lượng
/model/v1/models_saved/
/model/v2/models_saved/

# 3. Chặn các định dạng file nặng không cần thiết (nếu có)
*.h5
*.onnx
*.pycache
encoder/__pycache__/

# 4. Cấu hình cho Model v3 và v4:
# Đầu tiên chặn tất cả file .pth
*.pth
# Sau đó "mở chặn" cho các file model của version 3 và version 4
!/model/v3/models_saved/*.pth
!/model/v4/models_saved/*.pth