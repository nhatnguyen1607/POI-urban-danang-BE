{
  "name": "back-end",
  "version": "1.0.0",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "generate:synthetic": "node scripts/generate_synthetic_dataset.js",
    "evaluate:agent": "node scripts/evaluate_agent.js",
    "build:memory": "node scripts/build_agent_memory.js",
    "train:reranker": "node scripts/train_reranker.js",
    "train:agent-runtime": "npm run build:memory && npm run train:reranker && npm run evaluate:learning && npm run visualize:evaluation",
    "functions:build": "npm --prefix functions run build",
    "emulators:start": "npx --yes firebase-tools emulators:start --project demo-poi-urban --only functions,firestore",
    "emulators:verify-learning": "npx --yes firebase-tools emulators:exec --project demo-poi-urban --only functions,firestore \"node scripts/verify_online_learning_emulator.js\"",
    "export:representation-data": "node scripts/export_representation_training_data.js",
    "visualize:evaluation": "node scripts/visualize_agent_evaluation.js",
    "research:agent": "npm run generate:synthetic && npm run export:representation-data && npm run evaluate:learning && npm run visualize:evaluation",
    "evaluate:learning": "node scripts/evaluate_learning_loop.js",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "cors": "^2.8.6",
    "csv-parser": "^3.2.0",
    "express": "^5.2.1",
    "firebase-admin": "^14.0.0",
    "multer": "^2.1.1"
  }
}
